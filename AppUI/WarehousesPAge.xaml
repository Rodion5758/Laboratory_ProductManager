<Page x:Class="AppUI.WarehousesPAge"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AppUI"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page1">

    <StackPanel VerticalAlignment="Top" Margin="20">
        <TextBlock Text="The available warehouses:" FontWeight="Bold" FontStyle="Italic" FontSize="19" Padding="10"/>
        <ListBox x:Name="Warehouses" MouseDoubleClick="OpenWarehousePage">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Left">
                        
                        <TextBlock>
                            <Run Text="Name: " FontWeight="Bold" />
                            <Run Text="{Binding Name, Mode=OneWay}"/>
                        </TextBlock>
                        
                        <TextBlock>
                            <Run Text="Location: " FontWeight="Bold" />
                            <Run Text="{Binding Location, Mode=OneWay}"/>
                        </TextBlock>
                        
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</Page>

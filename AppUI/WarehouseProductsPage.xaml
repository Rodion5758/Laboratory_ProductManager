<UserControl x:Class="Laboratory_ProductManager.AppUI.WarehouseProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel VerticalAlignment="Top" Margin="20">
        <TextBlock Text="Warehouse details:" FontWeight="Bold" FontSize="15" Padding="10"/>
        <ProgressBar Height="6"
                     Margin="0,0,0,10"
                     IsIndeterminate="True"
                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <TextBlock Text="{Binding ErrorMessage}" Foreground="DarkRed" Margin="0,0,0,10"/>

        <StackPanel VerticalAlignment="Top" IsEnabled="{Binding IsNotBusy}">
            <TextBlock Text="Name:"/>
            <TextBox Width="260"
                     HorizontalAlignment="Left"
                     Margin="0,0,0,6"
                     Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="{Binding IsNotEditing}"/>

            <TextBlock Text="Location:"/>
            <ComboBox Width="260"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,6"
                      ItemsSource="{Binding LocationOptions}"
                      SelectedItem="{Binding EditLocation}"
                      IsEnabled="{Binding IsEditing}"/>

            <TextBlock>
                <Run Text="Total Products :"/>
                <Run Text="{Binding Warehouse.TotalProducts, Mode=OneWay}"/>
            </TextBlock>

            <TextBlock>
                <Run Text="Total Value :"/>
                <Run Text="{Binding Warehouse.TotalValue, Mode=OneWay}"/>
            </TextBlock>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Width="70"
                        Margin="0,0,10,0"
                        Content="Edit"
                        Command="{Binding EditWarehouseCommand}"/>
                <Button Width="70"
                        Margin="0,0,10,0"
                        Content="Save"
                        Command="{Binding SaveWarehouseCommand}"/>
                <Button Width="70"
                        Content="Cancel"
                        Command="{Binding CancelEditCommand}"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Text="The products in the warehouse:" FontWeight="Bold" FontStyle="Italic" FontSize="19" Padding="10"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" IsEnabled="{Binding IsNotBusy}">
            <TextBox Width="220"
                     Margin="0,0,10,0"
                     Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"/>
            <ComboBox Width="140"
                      Margin="0,0,10,0"
                      ItemsSource="{Binding ProductSortOptions}"
                      SelectedItem="{Binding ProductSortOption}"/>
            <Button Width="80"
                    Margin="0,0,10,0"
                    Content="Open"
                    Command="{Binding OpenProductCommand}"/>
            <Button Width="80"
                    Content="Delete"
                    Command="{Binding DeleteProductCommand}"/>
        </StackPanel>

        <ListBox x:Name="Products" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" IsEnabled="{Binding IsNotBusy}" MinHeight="130">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Left">
                        <TextBlock>
                        <Run Text="{Binding Name, Mode=OneWay}"/>
                        <Run Text=": "/>
                        <Run Text="{Binding Price, Mode=OneWay}"/>
                        <Run Text=" hrn, Quantity: "/>
                        <Run Text="{Binding Quantity, Mode=OneWay}"/>
                        <Run Text=", Total: "/>
                        <Run Text="{Binding TotalCost, Mode=OneWay}"/>
                        <Run Text=" hrn"/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Text="Add product:" FontWeight="Bold" Margin="0,12,0,6"/>
        <StackPanel IsEnabled="{Binding IsNotBusy}">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBox Width="180"
                         Margin="0,0,10,0"
                         Text="{Binding NewProductName, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBox Width="90"
                         Margin="0,0,10,0"
                         Text="{Binding NewProductPrice, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBox Width="90"
                         Margin="0,0,10,0"
                         Text="{Binding NewProductQuantity, UpdateSourceTrigger=PropertyChanged}"/>
                <ComboBox Width="140"
                          Margin="0,0,10,0"
                          ItemsSource="{Binding CategoryOptions}"
                          SelectedItem="{Binding NewProductCategory}"/>
                <Button Width="80"
                        Content="Add"
                        Command="{Binding AddProductCommand}"/>
            </StackPanel>
            <TextBox Width="520"
                     HorizontalAlignment="Left"
                     Text="{Binding NewProductDescription, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <Button Command="{Binding BackCommand}" Content="Back to warehouses" HorizontalAlignment="Left" IsEnabled="{Binding IsNotBusy}"/>
    </StackPanel>
    </ScrollViewer>
</UserControl>

<Page x:Class="AppUI.WarehouseProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AppUI"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page1">

    <StackPanel VerticalAlignment="Top" Margin="20">
        <TextBlock Text="Warehouse details:" FontWeight="Bold" FontSize="15" Padding="10"/>
        
        <StackPanel VerticalAlignment="Top">
            <TextBlock>
                <Run Text="Name :"/>
                <Run Text="{Binding Name, Mode=OneWay}"/>
            </TextBlock> 
                
            <TextBlock>
                <Run Text="Location :"/>
                <Run Text="{Binding Location, Mode=OneWay}"/>
            </TextBlock> 

            <TextBlock>
                <Run Text="Total Products :"/>
                <Run Text="{Binding TotalProducts, Mode=OneWay}"/>
            </TextBlock>

            <TextBlock>
                <Run Text="Total Value :"/>
                <Run Text="{Binding TotalValue, Mode=OneWay}"/>
            </TextBlock>
        </StackPanel>

        <TextBlock Text="The products in the warehouse:" FontWeight="Bold" FontStyle="Italic" FontSize="19" Padding="10"/>
        <ListBox x:Name="Products" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Left">
                        <TextBlock>
                        <Run Text="{Binding Name, Mode=OneWay}"/>
                        <Run Text=": "/>
                        <Run Text="{Binding Price, Mode=OneWay}"/>
                        <Run Text=" hrn, Quantity: "/>
                        <Run Text="{Binding Quantity, Mode=OneWay}"/>
                        <Run Text=", Total: "/>
                        <Run Text="{Binding TotalCost, Mode=OneWay}"/>
                        <Run Text=" hrn"/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Click="{Binding BackCommand}" Content="Back to warehouses" HorizontalAlignment="Left"/>
    </StackPanel>
</Page>

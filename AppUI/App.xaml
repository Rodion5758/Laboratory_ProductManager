<Application x:Class="AppUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AppUI"
             xmlns:vm="clr-namespace:Laboratory_ProductManager.AppUI.ViewModels">
    <Application.Resources>
        <DataTemplate DataType="{x:Type vm:WarehousesViewModel}">
            <local:WarehousesPAge/>
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:WarehouseProductsViewModel}">
            <local:WarehouseProductsPage/>
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:ProductDetailViewModel}">
            <local:ProductDetailsPage/>
        </DataTemplate>
    </Application.Resources>
</Application>


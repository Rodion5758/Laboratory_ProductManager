<Application x:Class="Laboratory_ProductManager.AppUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Laboratory_ProductManager.AppUI.ViewModels"
             xmlns:appUi="clr-namespace:Laboratory_ProductManager.AppUI">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <DataTemplate DataType="{x:Type vm:WarehousesViewModel}">
            <appUi:WarehousesPAge/>
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:WarehouseProductsViewModel}">
            <appUi:WarehouseProductsPage/>
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:ProductDetailViewModel}">
            <appUi:ProductDetailsPage/>
        </DataTemplate>
    </Application.Resources>
</Application>


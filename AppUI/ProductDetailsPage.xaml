<Page x:Class="AppUI.ProductDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AppUI"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page1">

    <StackPanel VerticalAlignment="Top" Margin="20">
        <TextBlock Text="Product details:" FontWeight="Bold" FontSize="15" Padding="10"/>
        
        <StackPanel VerticalAlignment="Top">
            <TextBlock>
                <Run Text="Name :"/>
                <Run Text="{Binding Name, Mode=OneWay}"/>
            </TextBlock> 
                
            <TextBlock>
                <Run Text="Category :"/>
                <Run Text="{Binding Category, Mode=OneWay}"/>
            </TextBlock> 
             <TextBlock>

                <Run Text="Price :"/>
                <Run Text="{Binding Price, Mode=OneWay}"/>
            </TextBlock> 
                                
            <TextBlock>
                <Run Text="Quantity :"/>
                <Run Text="{Binding Quantity, Mode=OneWay}"/>
            </TextBlock>

            <TextBlock>
                <Run Text="Total Cost :"/>
                <Run Text="{Binding TotalCost, Mode=OneWay}"/>
            </TextBlock>
                                
            <TextBlock>
                <Run Text="Description :"/>
                <Run Text="{Binding Description, Mode=OneWay}"/>
            </TextBlock>
        </StackPanel>
        <Button Click="{Binding BackCommand}" Content="Back to products" HorizontalAlignment="Left"/>
    </StackPanel>
</Page>

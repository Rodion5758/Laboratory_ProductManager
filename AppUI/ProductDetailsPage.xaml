<UserControl x:Class="Laboratory_ProductManager.AppUI.ProductDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel VerticalAlignment="Top" Margin="20">
        <TextBlock Text="Product details:" FontWeight="Bold" FontSize="15" Padding="10"/>
        <ProgressBar Height="6"
                     Margin="0,0,0,10"
                     IsIndeterminate="True"
                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <TextBlock Text="{Binding ErrorMessage}" Foreground="DarkRed" Margin="0,0,0,10"/>
        
        <StackPanel VerticalAlignment="Top" IsEnabled="{Binding IsNotBusy}">
            <TextBlock Text="Name:"/>
            <TextBox Width="280"
                     HorizontalAlignment="Left"
                     Margin="0,0,0,6"
                     Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="{Binding IsNotEditing}"/>

            <TextBlock Text="Category:"/>
            <ComboBox Width="280"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,6"
                      ItemsSource="{Binding CategoryOptions}"
                      SelectedItem="{Binding EditCategory}"
                      IsEnabled="{Binding IsEditing}"/>

            <TextBlock Text="Price:"/>
            <TextBox Width="280"
                     HorizontalAlignment="Left"
                     Margin="0,0,0,6"
                     Text="{Binding EditPrice, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="{Binding IsNotEditing}"/>

            <TextBlock Text="Quantity:"/>
            <TextBox Width="280"
                     HorizontalAlignment="Left"
                     Margin="0,0,0,6"
                     Text="{Binding EditQuantity, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="{Binding IsNotEditing}"/>

            <TextBlock>
                <Run Text="Total Cost :"/>
                <Run Text="{Binding Product.TotalCost, Mode=OneWay}"/>
            </TextBlock>

            <TextBlock Text="Description:" Margin="0,6,0,0"/>
            <TextBox Width="420"
                     HorizontalAlignment="Left"
                     Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="{Binding IsNotEditing}"/>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Width="70"
                        Margin="0,0,10,0"
                        Content="Edit"
                        Command="{Binding EditProductCommand}"/>
                <Button Width="70"
                        Margin="0,0,10,0"
                        Content="Save"
                        Command="{Binding SaveProductCommand}"/>
                <Button Width="70"
                        Content="Cancel"
                        Command="{Binding CancelEditCommand}"/>
            </StackPanel>
        </StackPanel>
        <Button Command="{Binding BackCommand}" Content="Back to products" HorizontalAlignment="Left" IsEnabled="{Binding IsNotBusy}"/>
    </StackPanel>
    </ScrollViewer>
</UserControl>
